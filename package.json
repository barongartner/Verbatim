{
  "name": "verbatim",
  "productName": "Verbatim",
  "version": "1.1.0",
  "description": "Free, private, offline audio transcription with speaker identification",
  "author": "The-Berin",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node build/make-icon.js",
    "dist:mac": "electron-builder --mac --x64",
    "dist:win": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^38.2.0",
    "electron-builder": "^26.0.12",
    "puppeteer-core": "^25.3.0",
    "sharp": "^0.34.2"
  },
  "build": {
    "appId": "com.berin.verbatim",
    "productName": "Verbatim",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "compression": "maximum",
    "files": [
      "main.js",
      "src/**/*",
      "package.json",
      "!vendor"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "identity": null,
      "icon": "build/icon.png",
      "extraResources": [
        {
          "from": "vendor/mac/bin",
          "to": "vendor/bin"
        },
        {
          "from": "vendor/mac/lib",
          "to": "vendor/lib"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "extraResources": [
        {
          "from": "vendor/win/bin",
          "to": "vendor/bin"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "dmg": {
      "title": "Verbatim ${version}"
    }
  }
}
